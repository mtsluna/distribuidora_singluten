---
const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>`,
    title: "Presencia Regional en Cuyo",
    desc: "Distribución directa en Mendoza, San Juan y San Luis. Conocemos cada mercado local y tenemos llegada donde otros distribuidores no llegan.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5zM8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/></svg>`,
    title: "20+ Años de Trayectoria",
    desc: "Oscar Mascareño lleva más de dos décadas en el sector, con el know-how para asesorar a tu negocio sobre los productos más rentables y demandados.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM10.854 8.854a.5.5 0 0 1-.708 0L8 6.707 5.854 8.854a.5.5 0 1 1-.708-.708l2.5-2.5a.5.5 0 0 1 .708 0l2.5 2.5a.5.5 0 0 1 0 .708z"/></svg>`,
    title: "Catálogo Amplio y Certificado",
    desc: "Más de 22 categorías de productos 100% libres de gluten, todos certificados por ANMAT. Desde alfajores y pastas hasta harinas, snacks y bebidas.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1H0V4zm0 3h16v5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V7zm3 2a.5.5 0 0 0 0 1h1a.5.5 0 0 0 0-1H3zm2.5 0a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5z"/></svg>`,
    title: "Precios Mayoristas Competitivos",
    desc: "Trabajamos exclusivamente con comercios, dietéticas, supermercados y gastronomía. Precios de mayorista para que tu negocio sea rentable.",
  },
];
---

<section id="por-que-elegirnos" class="py-20 lg:py-28 bg-white relative overflow-hidden">

  <!-- Subtle decorative shapes (matching hero style) -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-[#D4A574]/6 rounded-full translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#2D6A4F]/5 rounded-full -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-[#2D6A4F] text-sm font-semibold tracking-widest uppercase mb-4">
        Por qué elegirnos
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1C1C1C] leading-tight mb-4">
        La distribuidora sin gluten<br class="hidden sm:block" />
        <span class="text-[#2D6A4F]">del interior argentino</span>
      </h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        En un mercado donde el 98% de las distribuidoras están en Buenos Aires,
        nosotros estamos donde vos estás.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((f) => (
        <div class="group bg-[#FAFAF8] border border-gray-100 hover:border-[#2D6A4F]/20 hover:shadow-md rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1">
          <div class="w-11 h-11 rounded-xl bg-[#2D6A4F]/10 flex items-center justify-center text-[#2D6A4F] mb-5 group-hover:bg-[#2D6A4F]/15 transition-colors">
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="text-base font-semibold text-[#1C1C1C] mb-3">{f.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 text-center">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#2D6A4F] hover:bg-[#245840] text-white font-semibold px-8 py-4 rounded-full transition-all duration-300 hover:scale-105 text-base shadow-md"
      >
        Quiero ser cliente mayorista
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
