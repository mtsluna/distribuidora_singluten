---
---

<section id="contacto" class="py-20 lg:py-28 bg-[#FAFAF8]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <span class="inline-block text-[#2D6A4F] text-sm font-semibold tracking-widest uppercase mb-4">
        Contacto mayorista
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1C1C1C] mb-4">
        Solicitá precios mayoristas<br/>de productos sin gluten
      </h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Completá el formulario o contactanos directamente.
        Te respondemos a la brevedad con precios y disponibilidad.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

      <!-- Contact cards -->
      <div class="lg:col-span-2 space-y-4">
        <!-- WhatsApp -->
        <a
          href="https://wa.me/5492615080439?text=Hola%2C%20quiero%20solicitar%20informaci%C3%B3n%20sobre%20precios%20mayoristas%20de%20productos%20sin%20gluten."
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 p-5 bg-[#25D366]/5 border border-[#25D366]/20 hover:border-[#25D366]/50 rounded-2xl transition-all hover:shadow-md"
        >
          <div class="w-12 h-12 rounded-xl bg-[#25D366] flex items-center justify-center flex-shrink-0 shadow-md shadow-green-500/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-xs font-semibold text-[#25D366] uppercase tracking-wide mb-0.5">WhatsApp</div>
            <div class="font-semibold text-[#1C1C1C] text-sm group-hover:text-[#25D366] transition-colors">+54 9 261 508-0439</div>
            <div class="text-xs text-gray-500">Respuesta inmediata</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-gray-300 group-hover:text-[#25D366] transition-colors flex-shrink-0" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
          </svg>
        </a>

        <!-- Phone -->
        <a
          href="tel:+5492615080439"
          class="group flex items-center gap-4 p-5 bg-[#2D6A4F]/5 border border-[#2D6A4F]/20 hover:border-[#2D6A4F]/50 rounded-2xl transition-all hover:shadow-md"
        >
          <div class="w-12 h-12 rounded-xl bg-[#2D6A4F] flex items-center justify-center flex-shrink-0 shadow-md shadow-green-800/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="white" viewBox="0 0 16 16">
              <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-xs font-semibold text-[#2D6A4F] uppercase tracking-wide mb-0.5">Teléfono</div>
            <div class="font-semibold text-[#1C1C1C] text-sm group-hover:text-[#2D6A4F] transition-colors">+54 9 261 508-0439</div>
            <div class="text-xs text-gray-500">Lunes a Viernes, 9 a 18hs</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-gray-300 group-hover:text-[#2D6A4F] transition-colors flex-shrink-0" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
          </svg>
        </a>

        <!-- Note -->
        <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl">
          <p class="text-xs text-amber-800">
            <strong>Solo venta mayorista.</strong> Realizamos despachos a dietéticas, almacenes,
            supermercados, restaurantes y comercios de toda la región.
          </p>
        </div>
      </div>

      <!-- Contact form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          class="bg-[#FAFAF8] rounded-2xl border border-gray-100 p-8 shadow-sm"
        >

          <h3 class="text-xl font-semibold text-[#1C1C1C] mb-6">Solicitar información de precios</h3>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1.5">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm bg-white"
              />
            </div>
            <div>
              <label for="negocio" class="block text-sm font-medium text-gray-700 mb-1.5">Nombre del negocio *</label>
              <input
                type="text"
                id="negocio"
                name="negocio"
                required
                placeholder="Dietética, almacén, restaurante..."
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm bg-white"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-700 mb-1.5">Teléfono / WhatsApp *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                placeholder="+54 9 261 000 0000"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm bg-white"
              />
            </div>
            <div>
              <label for="provincia" class="block text-sm font-medium text-gray-700 mb-1.5">Provincia</label>
              <select
                id="provincia"
                name="provincia"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm bg-white"
              >
                <option value="">Seleccioná tu provincia</option>
                <option>Mendoza</option>
                <option>San Juan</option>
                <option>La Rioja</option>
                <option>San Luis</option>
                <option>Neuquén</option>
                <option>Otra</option>
              </select>
            </div>
          </div>

          <div class="mb-5">
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm bg-white"
            />
          </div>

          <div class="mb-6">
            <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-1.5">¿Qué categorías te interesan?</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="3"
              placeholder="Ej: alfajores, galletitas, harinas, snacks..."
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2D6A4F] focus:ring-2 focus:ring-[#2D6A4F]/20 outline-none transition-all text-sm resize-none bg-white"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white font-semibold py-4 px-8 rounded-xl transition-all duration-300 hover:scale-[1.02] shadow-md hover:shadow-lg text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
            Enviar por WhatsApp
          </button>
          <p class="text-xs text-gray-400 text-center mt-3">
            Se abrirá WhatsApp con tu consulta lista para enviar.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', function (e) {
    e.preventDefault();

    const nombre   = (document.getElementById('nombre')   as HTMLInputElement).value.trim();
    const negocio  = (document.getElementById('negocio')  as HTMLInputElement).value.trim();
    const telefono = (document.getElementById('telefono') as HTMLInputElement).value.trim();
    const provincia = (document.getElementById('provincia') as HTMLSelectElement).value;
    const email    = (document.getElementById('email')    as HTMLInputElement).value.trim();
    const mensaje  = (document.getElementById('mensaje')  as HTMLTextAreaElement).value.trim();

    let text = `Hola, quiero solicitar información sobre precios mayoristas.\n\n`;
    text += `*Nombre:* ${nombre}\n`;
    text += `*Negocio:* ${negocio}\n`;
    text += `*Teléfono:* ${telefono}\n`;
    if (provincia) text += `*Provincia:* ${provincia}\n`;
    if (email)     text += `*Email:* ${email}\n`;
    if (mensaje)   text += `*Categorías de interés:* ${mensaje}\n`;

    window.open(`https://wa.me/5492615080439?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>
