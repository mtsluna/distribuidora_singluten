---
import '../styles/global.css';
import { categories } from '../data/categories.ts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Distribuidora Sin Gluten | Mayorista Sin TACC | Cuyo, Argentina",
  description = "Distribuidora mayorista de productos sin gluten y sin TACC en Cuyo. Más de 20 años de experiencia abasteciendo Mendoza, San Juan y San Luis.",
  image = `https://www.distribuidorasingluten.com.ar/images/logo.png`,
} = Astro.props;

const canonicalURL = Astro.url.toString();
const SITE_URL = "https://www.distribuidorasingluten.com.ar";

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WholesaleStore", "LocalBusiness"],
      "@id": `${SITE_URL}/#business`,
      "name": "Distribuidora Sin Gluten",
      "alternateName": ["Distribuidora Sin Gluten", "Mayorista Sin TACC Cuyo"],
      "description": "Distribuidora mayorista de productos sin gluten y sin TACC en la región de Cuyo, Argentina. Más de 20 años de trayectoria. 336 productos certificados por ANMAT en 22 categorías.",
      "url": SITE_URL,
      "telephone": "+5492615080439",
      "email": "singlutenmendoza@gmail.com",
      "foundingDate": "2005",
      "priceRange": "$$",
      "currenciesAccepted": "ARS",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mendoza",
        "addressRegion": "Mendoza",
        "addressCountry": "AR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -32.88932,
        "longitude": -68.84720
      },
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Mendoza", "addressCountry": "AR" },
        { "@type": "AdministrativeArea", "name": "San Juan", "addressCountry": "AR" },
        { "@type": "AdministrativeArea", "name": "San Luis", "addressCountry": "AR" }
      ],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "18:00"
      },
      "founder": {
        "@type": "Person",
        "@id": `${SITE_URL}/#founder`,
        "name": "Distribuidora Sin Gluten"
      },
      "knowsAbout": [
        "productos sin gluten", "sin TACC", "alimentos para celíacos",
        "distribución mayorista de alimentos", "normativa ANMAT alimentos sin gluten"
      ],
      "makesOffer": {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Distribución mayorista de productos sin gluten",
          "description": "Venta y distribución al por mayor de más de 336 productos sin gluten certificados por ANMAT para dietéticas, almacenes, supermercados y gastronomía en Cuyo."
        },
        "eligibleCustomerType": "http://purl.org/goodrelations/v1#Business",
        "areaServed": "Cuyo, Argentina"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "@id": `${SITE_URL}/#catalog`,
        "name": "Catálogo de productos sin gluten",
        "numberOfItems": 336,
        "description": "336 productos sin gluten y sin TACC certificados por ANMAT, en 22 categorías."
      },
      "logo": {
        "@type": "ImageObject",
        "url": `${SITE_URL}/images/logo.png`
      },
      "image": `${SITE_URL}/images/logo.png`,
      "sameAs": [
        `https://wa.me/5492615080439`
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      "url": SITE_URL,
      "name": "Distribuidora Sin Gluten",
      "description": "Distribuidora mayorista de productos sin gluten y sin TACC en Cuyo, Argentina.",
      "publisher": { "@id": `${SITE_URL}/#business` },
      "inLanguage": "es-AR"
    },
    {
      "@type": "WebPage",
      "@id": `${SITE_URL}/#webpage`,
      "url": SITE_URL,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${SITE_URL}/#website` },
      "about": { "@id": `${SITE_URL}/#business` },
      "inLanguage": "es-AR",
      "breadcrumb": { "@id": `${SITE_URL}/#breadcrumb` }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${SITE_URL}/#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE_URL }
      ]
    },
    {
      "@type": "ItemList",
      "@id": `${SITE_URL}/#category-list`,
      "name": "Categorías de productos sin gluten",
      "description": "22 categorías de productos sin gluten y sin TACC distribuidos por Distribuidora Sin Gluten en la región de Cuyo.",
      "numberOfItems": categories.length,
      "itemListOrder": "https://schema.org/ItemListOrderAscending",
      "itemListElement": categories.map((cat, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": cat.name,
        "url": `${SITE_URL}/#categorias`
      }))
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Distribuidora Sin Gluten" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body class="bg-[#FAFAF8] text-[#1C1C1C] font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #2D6A4F;
    --color-accent: #D4A574;
    --color-bg: #FAFAF8;
    --color-text: #1C1C1C;
    --color-muted: #6B7280;
    --color-whatsapp: #25D366;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', sans-serif;
  }

  h1, h2, h3 {
    font-family: 'Playfair Display', serif;
  }
</style>
